variable        NSTEPS          equal 1
variable        THERMO_FREQ     equal 100
variable        DUMP_FREQ       equal 10
variable        restart         equal 0
variable        TEMP            equal 300.000000
variable        PRESS           equal 0.000000
variable        TAU_T           equal 0.050000
variable        TAU_P           equal 0.500000

package kokkos neigh full comm device
newton on

units           metal
boundary        p p p
atom_style      atomic

neighbor        1.0 bin
neigh_modify    delay 10

#box              tilt large
if "${restart} > 0" then "read_restart lmps.restart.*" else "read_data conf.lmp"
#change_box       all triclinic
replicate   19 19 19

mass   1    15.999
mass   2    1.00784
pair_style   matpl/nep/kk nep.txt
pair_coeff       * * O H

thermo_style    custom step temp pe ke etotal press vol
thermo          ${THERMO_FREQ}

if "${restart} == 0" then "velocity        all create ${TEMP} 35826"
fix             1 all nvt/kk temp ${TEMP} ${TEMP} ${TAU_T} #iso ${PRESS} ${PRESS} ${TAU_P}

timestep        0.000500
run             ${NSTEPS} upto

package kokkos neigh full comm device
newton on

variable        NSTEPS          equal 100
variable        THERMO_FREQ     equal 10
variable        DUMP_FREQ       equal 10
variable        restart         equal 0
variable        TEMP            equal 300.000000
variable        PRESS           equal 0.000000
variable        TAU_T           equal 0.100000
variable        TAU_P           equal 0.500000

units           metal
boundary        p p p
atom_style      atomic

neighbor        1.0 bin
neigh_modify    delay 10

box              tilt large
read_data        lmp.in
change_box       all triclinic


replicate 70 70  70

mass   1    178.49
mass   2    15.999
pair_style   matpl/nep/kk  nep.txt
pair_coeff       * * Hf O

thermo_style    custom step temp pe ke etotal press vol
thermo          ${THERMO_FREQ}

velocity        all create ${TEMP} 35826
fix             1 all npt/kk temp ${TEMP} ${TEMP} ${TAU_T} iso ${PRESS} ${PRESS} ${TAU_P}

timestep        0.002000
run             ${NSTEPS} upto

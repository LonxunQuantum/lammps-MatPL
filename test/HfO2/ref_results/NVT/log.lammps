thermo_style    custom step temp v_pe_peratom v_W_xx v_W_yy v_W_zz v_W_xy v_W_xz v_W_yz
thermo          ${THERMO_FREQ}
thermo          1

if "${restart} == 0" then "velocity        all create ${TEMP} 35826"
velocity        all create ${TEMP} 35826
velocity        all create 1200 35826
fix             1 all nvt temp ${TEMP} ${TEMP} ${TAU_T}
fix             1 all nvt temp 1200 ${TEMP} ${TAU_T}
fix             1 all nvt temp 1200 1200 ${TAU_T}
fix             1 all nvt temp 1200 1200 0.1

timestep        0.002000
dump            1 all custom ${DUMP_FREQ} HfO2.dump id type x y z fx fy fz vx vy vz
dump            1 all custom 1 HfO2.dump id type x y z fx fy fz vx vy vz
dump_modify     1 sort id

run             ${NSTEPS}
run             100

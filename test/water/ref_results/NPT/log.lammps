LAMMPS (2 Aug 2023 - Update 4)
  using 1 OpenMP thread(s) per MPI task
variable        NSTEPS          equal 100
variable        THERMO_FREQ     equal 1
variable        DUMP_FREQ       equal 1
variable        restart         equal 0
variable        TEMP            equal 300.000000
variable        PRESS           equal 1.000000
variable        TAU_T           equal 0.050000
variable        TAU_P           equal 0.500000

units           metal
boundary        p p p
atom_style      atomic

neighbor        1.0 bin
neigh_modify    delay 10

if "${restart} > 0" then "read_restart lmps.restart.*" else "read_data ../../conf.lmp"
read_data ../../conf.lmp
Reading data file ...
  orthogonal box = (0 0 0) to (18.6206 18.6206 18.6206)
  1 by 1 by 1 MPI processor grid
  reading atoms ...
  648 atoms
  read_data CPU = 0.004 seconds

mass   1    15.999
mass   2    1.00784
pair_style   nep
pair_coeff       * * ../../nep.txt O H

compute    allPe   all   pe
compute    myVirial all pressure NULL virial
variable   N_total equal count(all)
variable   pe_peratom equal c_allPe/v_N_total
variable   W_xx  equal c_myVirial[1]/v_N_total
variable   W_yy  equal c_myVirial[2]/v_N_total
variable   W_zz  equal c_myVirial[3]/v_N_total
variable   W_xy  equal c_myVirial[4]/v_N_total
variable   W_xz  equal c_myVirial[5]/v_N_total
variable   W_yz  equal c_myVirial[6]/v_N_total

thermo_style    custom step temp v_pe_peratom v_W_xx v_W_yy v_W_zz v_W_xy v_W_xz v_W_yz
thermo          ${THERMO_FREQ}
thermo          1

if "${restart} == 0" then "velocity        all create ${TEMP} 35826"
velocity        all create ${TEMP} 35826
velocity        all create 300 35826
fix             1 all npt temp ${TEMP} ${TEMP} ${TAU_T} iso ${PRESS} ${PRESS} ${TAU_P}
fix             1 all npt temp 300 ${TEMP} ${TAU_T} iso ${PRESS} ${PRESS} ${TAU_P}
fix             1 all npt temp 300 300 ${TAU_T} iso ${PRESS} ${PRESS} ${TAU_P}
fix             1 all npt temp 300 300 0.05 iso ${PRESS} ${PRESS} ${TAU_P}
fix             1 all npt temp 300 300 0.05 iso 1 ${PRESS} ${TAU_P}
fix             1 all npt temp 300 300 0.05 iso 1 1 ${TAU_P}
fix             1 all npt temp 300 300 0.05 iso 1 1 0.5
timestep        0.000500
#run             ${NSTEPS}
dump            1 all custom ${DUMP_FREQ} water.dump id type x y z fx fy fz vx vy vz
dump            1 all custom 1 water.dump id type x y z fx fy fz vx vy vz
dump_modify     1 sort id

run             ${NSTEPS}
run             100

LAMMPS (2 Aug 2023 - Update 4)
  using 1 OpenMP thread(s) per MPI task
# =========================================
# LAMMPS NEP Benchmark: WMoTaV refractory HEA
# Potential: NEP (nep)
# Elements: W Mo Ta V
# Structure: BCC random solid solution (a ~ 3.16 A)
# Atoms: 128000 (250 x 8x8x8)
# =========================================

# --- Simulation Parameters ---
variable        NSTEPS     equal 100
variable        THERMO     equal 1
variable        TEMP       equal 300
variable        PRES       equal 0
variable        TAU_T      equal 0.1
variable        TAU_P      equal 1.0
variable        TSTEP      equal 0.001

# --- System Setup ---
units           metal
boundary        p p p
atom_style      atomic

read_data       ../../data.lmp
Reading data file ...
  orthogonal box = (0 0 0) to (15.8 15.8 15.8)
  1 by 1 by 1 MPI processor grid
  reading atoms ...
  250 atoms
  read_data CPU = 0.016 seconds
#replicate       8 8 8

# --- Potential ---
mass            1 183.84
mass            2 95.95
mass            3 180.9479
mass            4 50.9415

pair_style      nep
pair_coeff      * * ../../nep.txt W Mo Ta V

# --- Neighbor Settings ---
neighbor        1.0 bin
neigh_modify    every 10 delay 0 check no

# --- Output ---
thermo          ${THERMO}
thermo          1
compute    allPe   all   pe
compute    myVirial all pressure NULL virial
variable   N_total equal count(all)
variable   pe_peratom equal c_allPe/v_N_total
variable   W_xx  equal c_myVirial[1]/v_N_total
variable   W_yy  equal c_myVirial[2]/v_N_total
variable   W_zz  equal c_myVirial[3]/v_N_total
variable   W_xy  equal c_myVirial[4]/v_N_total
variable   W_xz  equal c_myVirial[5]/v_N_total
variable   W_yz  equal c_myVirial[6]/v_N_total

thermo_style    custom step temp v_pe_peratom v_W_xx v_W_yy v_W_zz v_W_xy v_W_xz v_W_yz

# --- Dynamics ---
velocity        all create ${TEMP} 12345 dist gaussian mom yes rot yes
velocity        all create 300 12345 dist gaussian mom yes rot yes
fix             1 all nvt temp ${TEMP} ${TEMP} ${TAU_T}
fix             1 all nvt temp 300 ${TEMP} ${TAU_T}
fix             1 all nvt temp 300 300 ${TAU_T}
fix             1 all nvt temp 300 300 0.1
timestep        ${TSTEP}
timestep        0.001
dump            1 all custom 1 lammps.dump id type x y z fx fy fz vx vy vz
dump_modify     1 sort id

# --- Run ---
run             ${NSTEPS}
run             100

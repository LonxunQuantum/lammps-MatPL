LAMMPS (2 Aug 2023 - Update 4)
  using 1 OpenMP thread(s) per MPI task
variable        NSTEPS          equal 100
variable        THERMO_FREQ     equal 1
variable        DUMP_FREQ       equal 1
variable        restart         equal 0
variable        TEMP            equal 300.000000
variable        PRESS           equal 0.000000
variable        TAU_T           equal 0.100000
variable        TAU_P           equal 1.000000

units           metal
boundary        p p p
atom_style      atomic

neighbor        1.0 bin
neigh_modify    delay 10

if "${restart} > 0" then "read_restart lmps.restart.*" else "read_data ../../conf.lmp"
read_data ../../conf.lmp
Reading data file ...
  orthogonal box = (0 0 0) to (4.9354483 4.2742236 24.342519)
  1 by 1 by 1 MPI processor grid
  reading atoms ...
  16 atoms
  read_data CPU = 0.004 seconds

mass   1     12.0096
pair_style   nep
pair_coeff       * * ../../nep.txt C

replicate    5  6  1
Replication is creating a 5x6x1 = 30 times larger system...
  orthogonal box = (0 0 0) to (24.677241 25.645342 24.342519)
  1 by 1 by 1 MPI processor grid
  480 atoms
  replicate CPU = 0.000 seconds

compute    allPe   all   pe
compute    myVirial all pressure NULL virial
variable   N_total equal count(all)
variable   pe_peratom equal c_allPe/v_N_total
variable   W_xx  equal c_myVirial[1]/v_N_total
variable   W_yy  equal c_myVirial[2]/v_N_total
variable   W_zz  equal c_myVirial[3]/v_N_total
variable   W_xy  equal c_myVirial[4]/v_N_total
variable   W_xz  equal c_myVirial[5]/v_N_total
variable   W_yz  equal c_myVirial[6]/v_N_total

thermo_style    custom step temp v_pe_peratom v_W_xx v_W_yy v_W_zz v_W_xy v_W_xz v_W_yz
thermo          ${THERMO_FREQ}
thermo          1

if "${restart} == 0" then "velocity        all create ${TEMP} 35826"
velocity        all create ${TEMP} 35826
velocity        all create 300 35826
fix             1 all npt temp ${TEMP} ${TEMP} ${TAU_T} x ${PRESS} ${PRESS} ${TAU_P}  y ${PRESS} ${PRESS} ${TAU_P}
fix             1 all npt temp 300 ${TEMP} ${TAU_T} x ${PRESS} ${PRESS} ${TAU_P}  y ${PRESS} ${PRESS} ${TAU_P}
fix             1 all npt temp 300 300 ${TAU_T} x ${PRESS} ${PRESS} ${TAU_P}  y ${PRESS} ${PRESS} ${TAU_P}
fix             1 all npt temp 300 300 0.1 x ${PRESS} ${PRESS} ${TAU_P}  y ${PRESS} ${PRESS} ${TAU_P}
fix             1 all npt temp 300 300 0.1 x 0 ${PRESS} ${TAU_P}  y ${PRESS} ${PRESS} ${TAU_P}
fix             1 all npt temp 300 300 0.1 x 0 0 ${TAU_P}  y ${PRESS} ${PRESS} ${TAU_P}
fix             1 all npt temp 300 300 0.1 x 0 0 1  y ${PRESS} ${PRESS} ${TAU_P}
fix             1 all npt temp 300 300 0.1 x 0 0 1  y 0 ${PRESS} ${TAU_P}
fix             1 all npt temp 300 300 0.1 x 0 0 1  y 0 0 ${TAU_P}
fix             1 all npt temp 300 300 0.1 x 0 0 1  y 0 0 1
timestep        0.001000
#run             ${NSTEPS}
dump            1 all custom ${DUMP_FREQ} lammps.dump id type x y z fx fy fz vx vy vz
dump            1 all custom 1 lammps.dump id type x y z fx fy fz vx vy vz
dump_modify     1 sort id

run             ${NSTEPS}
run             100
